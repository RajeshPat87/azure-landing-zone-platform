# Copy to .claude/hooks/config.env (gitignored) and edit. Sourced by every hook.

# Path to the rotating Azure lab credentials file (JSON from
# `az ad sp create-for-rbac`, or a KEY=VALUE .env). If unset, the creds script
# probes a list of default locations (see azure-lab-creds.sh).
# export ALZ_AZURE_CREDS_FILE="/mnt/c/Users/sound/azure-lab-creds.json"

# Refresh creds when older than this many seconds (default 3000 = 50 min).
# export ALZ_CREDS_MAX_AGE=3000

# Where per-user runtime state (audit log, creds env, timestamps) lives.
# export ALZ_STATE_DIR="$HOME/.claude/alz"
